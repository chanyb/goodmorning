<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr name="src" format="reference" />
    <attr name="text" format="reference|string" />
    <attr name="textSize" format="reference|string" />
    <attr name="textStyle" format="reference|string" />
    <attr name="hint" format="reference|string" />
    <attr name="backgroundTint" format="reference|color" />
    <attr name="textColor" format="reference|color" />
    <attr name="inputType" format="string" />
    <attr name="horizontal_bias" format="float" />
    <attr name="color" format="reference|color" />

    <declare-styleable name="Triangle">
        <attr name="orientation">
            <enum name="normal" value="0"/>
            <enum name="reverse" value="1"/>
        </attr>
        <attr name="color" />
    </declare-styleable>

    <declare-styleable name="Circle">
        <attr name="color" />
    </declare-styleable>

</resources>

