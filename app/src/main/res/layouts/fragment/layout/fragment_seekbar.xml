<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/seekbar_background"
            android:layout_width="0dp"
            android:layout_height="70dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0">

            <kr.co.kworks.goodmorning.view.Circle
                android:id="@+id/circle_start"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:color="@color/white"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                />

            <View
                android:id="@+id/rect"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="35dp"
                android:layout_marginEnd="35dp"
                />

            <kr.co.kworks.goodmorning.view.Circle
                android:id="@+id/circle_end"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:color="@color/white"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1"
                />


            <TextView
                android:id="@+id/txt_slide_to_unlock"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="@string/str_lock_drag"
                android:textStyle="bold"
                android:gravity="center"
                android:textSize="22dp"
                android:fontFamily="@font/pretendard_semibold"
                android:textColor="@color/black"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

            <kr.co.kworks.goodmorning.view.Circle
                android:id="@+id/circle_start_dragged"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="2dp"
                app:color="@color/orange_f59e0b"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>



        <SeekBar
            android:id="@+id/seekbar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:paddingStart="35dp"
            android:paddingEnd="35dp"
            app:layout_constraintTop_toTopOf="@id/seekbar_background"
            app:layout_constraintBottom_toBottomOf="@id/seekbar_background"
            app:layout_constraintStart_toStartOf="@id/seekbar_background"
            app:layout_constraintEnd_toEndOf="@id/seekbar_background"
            android:progressDrawable="@null"
            android:max="100"
            tools:ignore="RtlSymmetry"
            app:layout_constraintVertical_bias="0"
            />

        <View
            android:id="@+id/seeker_background"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="35dp"
            android:layout_marginEnd="35dp"
            android:background="@color/orange_f59e0b"
            app:layout_constraintTop_toTopOf="@id/seeker"
            app:layout_constraintBottom_toBottomOf="@id/seeker"
            app:layout_constraintStart_toStartOf="@id/seekbar"
            app:layout_constraintEnd_toEndOf="@id/seeker"
            />

        <kr.co.kworks.goodmorning.view.Circle
            android:id="@+id/seeker"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="2dp"
            app:color="@color/blue_2563EB"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintTop_toTopOf="@id/seekbar"
            app:layout_constraintBottom_toBottomOf="@id/seekbar"
            app:layout_constraintStart_toStartOf="@id/seekbar"
            app:layout_constraintEnd_toEndOf="@id/seekbar"
            app:layout_constraintHorizontal_bias="0"
            />

        <ImageView
            android:id="@+id/img_seeker"
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:layout_constraintTop_toTopOf="@id/seeker"
            app:layout_constraintBottom_toBottomOf="@id/seeker"
            app:layout_constraintStart_toStartOf="@id/seeker"
            app:layout_constraintEnd_toEndOf="@id/seeker"
            android:src="@drawable/icon_arrow"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>