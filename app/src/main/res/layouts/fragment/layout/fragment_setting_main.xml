<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lo_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_header"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.1"
            app:layout_constraintVertical_bias="0" />

        <View
            android:id="@+id/top_margin"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintHeight_percent="0.033333"
            app:layout_constraintTop_toBottomOf="@id/lo_header"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0"
            />

        <!-- 디바이스 정보 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_device_info"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/background_edge_10_transparent_white_10"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintTop_toBottomOf="@id/top_margin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.02"
            app:layout_constraintHeight_percent="0.107"
            app:layout_constraintVertical_bias="0">

            <TextView
                android:id="@+id/txt_device_info"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:textColor="@color/white"
                android:fontFamily="@font/pretendard_bold"
                android:textSize="50dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="center"
                android:text="@string/str_setting_menu_1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.441"
                app:layout_constraintHeight_percent="0.531"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/device_info_margin"
            android:layout_width="1dp"
            android:layout_height="0dp"
            app:layout_constraintHeight_percent="0.01666666666667"
            app:layout_constraintTop_toBottomOf="@id/lo_device_info"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            />

        <!-- 소프트웨어 업데이트 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_software_update"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/background_edge_10_transparent_outline_white_10"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintTop_toBottomOf="@id/device_info_margin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.02"
            app:layout_constraintHeight_percent="0.107"
            app:layout_constraintVertical_bias="0">

            <TextView
                android:id="@+id/txt_software_update"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:textColor="@color/gray_81838f"
                android:fontFamily="@font/pretendard_medium"
                android:textSize="50dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="center"
                android:text="@string/str_setting_menu_2"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.6527777777777778"
                app:layout_constraintHeight_percent="0.531"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/software_update_margin"
            android:layout_width="1dp"
            android:layout_height="0dp"
            app:layout_constraintHeight_percent="0.01666666666667"
            app:layout_constraintTop_toBottomOf="@id/lo_software_update"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            />

        <!-- 네트워크 상태 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_network_status"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/background_edge_10_transparent_outline_white_10"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintTop_toBottomOf="@id/software_update_margin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.02"
            app:layout_constraintHeight_percent="0.107"
            app:layout_constraintVertical_bias="0">

            <TextView
                android:id="@+id/txt_network_status"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:textColor="@color/gray_81838f"
                android:fontFamily="@font/pretendard_medium"
                android:textSize="50dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="center"
                android:text="@string/str_setting_menu_3"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.441"
                app:layout_constraintHeight_percent="0.531"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/network_status_margin"
            android:layout_width="1dp"
            android:layout_height="0dp"
            app:layout_constraintHeight_percent="0.01666666666667"
            app:layout_constraintTop_toBottomOf="@id/lo_network_status"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            />

        <!-- 앱 종료 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_app_exit"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/background_edge_10_transparent_outline_white_10"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintTop_toBottomOf="@id/network_status_margin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.02"
            app:layout_constraintHeight_percent="0.107"
            app:layout_constraintVertical_bias="0">

            <TextView
                android:id="@+id/txt_app_exit"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:textColor="@color/gray_81838f"
                android:fontFamily="@font/pretendard_medium"
                android:textSize="50dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="center"
                android:text="@string/str_setting_menu_4"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.441"
                app:layout_constraintHeight_percent="0.531"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/device_info_margin_right"
            android:layout_width="0dp"
            android:layout_height="1dp"
            app:layout_constraintWidth_percent="0.011"
            app:layout_constraintTop_toTopOf="@id/lo_device_info"
            app:layout_constraintStart_toEndOf="@id/lo_device_info"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_setting_content"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.66"
            app:layout_constraintHeight_percent="0.8333333333333333"
            app:layout_constraintTop_toBottomOf="@id/top_margin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/device_info_margin_right"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintVertical_bias="0">

        </androidx.constraintlayout.widget.ConstraintLayout>


        <include
            android:id="@+id/dialog"
            layout="@layout/item_dialog" />

        <include
            android:id="@+id/dialog_force"
            layout="@layout/item_vehicle_force_mapping" />

        <include
            android:id="@+id/confirm_app_exit"
            layout="@layout/confirm_app_exit" />



    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>