<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lo_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <View
            android:id="@+id/sensor_guide"
            android:layout_width="0dp"
            android:layout_height="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintWidth_percent="0.0083333333"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_sensor"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/sensor_guide"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.5104166666666667"
            app:layout_constraintHeight_percent="0.7333333333333333"
            android:background="@drawable/background_edge_transparent_10"
            app:layout_constraintHorizontal_bias="0"
            android:clipToOutline="true">

            <View
                android:id="@+id/start_padding"
                android:layout_width="0dp"
                android:layout_height="10dp"
                app:layout_constraintWidth_percent="0.03"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                />

            <View
                android:id="@+id/end_padding"
                android:layout_width="0dp"
                android:layout_height="1dp"
                app:layout_constraintWidth_percent="0.02"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_direction_wind"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintWidth_percent="0.19"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/start_padding"
                app:layout_constraintEnd_toStartOf="@id/lo_speed_wind"
                app:layout_constraintHeight_percent="0.8181818181818182">

                <TextView
                    android:id="@+id/direction_wind_title"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:text="풍향"
                    android:textColor="@color/white"
                    android:fontFamily="@font/pretendard_medium"
                    android:textSize="80dp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeStepGranularity="1dp"
                    android:maxLines="1"
                    android:gravity="center_vertical"
                    app:layout_constraintWidth_percent="0.37"
                    app:layout_constraintHeight_percent="0.6944444444444444"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    />

                <TextView
                    android:id="@+id/direction_wind_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="남서"
                    android:textColor="@color/white"
                    android:fontFamily="@font/pretendard_bold"
                    android:textSize="80dp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeStepGranularity="1dp"
                    android:maxLines="1"
                    android:gravity="center_vertical|start"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/direction_wind_title"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_speed_wind"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:minWidth="20dp"
                app:layout_constraintWidth_percent="0.315"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/lo_direction_wind"
                app:layout_constraintEnd_toStartOf="@id/lo_temperature"
                app:layout_constraintHeight_percent="0.8181818181818182">

                <TextView
                    android:id="@+id/speed_wind_title"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:text="풍속"
                    android:textColor="@color/white"
                    android:fontFamily="@font/pretendard_medium"
                    android:textSize="80dp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeStepGranularity="1dp"
                    android:maxLines="1"
                    android:gravity="center_vertical"
                    app:layout_constraintHeight_percent="0.6944444444444444"
                    app:layout_constraintWidth_percent="0.23"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    />

                <TextView
                    android:id="@+id/speed_wind_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="23.3m/s"
                    android:textColor="@color/sensor_yellow"
                    android:fontFamily="@font/pretendard_bold"
                    android:textSize="80dp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeStepGranularity="1dp"
                    android:maxLines="1"
                    android:gravity="center_vertical"
                    app:layout_constraintWidth_percent="0.76"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/speed_wind_title"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_temperature"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:minWidth="20dp"
                app:layout_constraintWidth_percent="0.23"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/lo_speed_wind"
                app:layout_constraintEnd_toStartOf="@id/lo_humidity"
                app:layout_constraintHeight_percent="0.8181818181818182">

                <TextView
                    android:id="@+id/temperature_title"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:text="온도"
                    android:textColor="@color/white"
                    android:fontFamily="@font/pretendard_medium"
                    android:textSize="80dp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeStepGranularity="1dp"
                    android:maxLines="1"
                    android:gravity="center_vertical"
                    app:layout_constraintHeight_percent="0.6944444444444444"
                    app:layout_constraintWidth_percent="0.3"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    />

                <TextView
                    android:id="@+id/temperature_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="54˚C"
                    android:textColor="@color/sensor_orange"
                    android:fontFamily="@font/pretendard_bold"
                    android:textSize="80dp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeStepGranularity="1dp"
                    android:maxLines="1"
                    android:gravity="center_vertical"
                    app:layout_constraintWidth_percent="0.68"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/temperature_title"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_humidity"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:minWidth="20dp"
                app:layout_constraintWidth_percent="0.2"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/end_padding"
                app:layout_constraintHeight_percent="0.8181818181818182"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintVertical_bias="0.495"
                app:layout_constraintHorizontal_bias="1">

                <TextView
                    android:id="@+id/humidity_title"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:autoSizeStepGranularity="1dp"
                    android:autoSizeTextType="uniform"
                    android:fontFamily="@font/pretendard_medium"
                    android:gravity="center_vertical"
                    android:maxLines="1"
                    android:text="습도"
                    android:textColor="@color/white"
                    android:textSize="80dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHeight_percent="0.6944444444444444"
                    app:layout_constraintHorizontal_bias="0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_percent="0.33" />

                <TextView
                    android:id="@+id/humidity_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:autoSizeStepGranularity="1dp"
                    android:autoSizeTextType="uniform"
                    android:fontFamily="@font/pretendard_bold"
                    android:gravity="center_vertical"
                    android:maxLines="1"
                    android:text="80%"
                    android:textColor="@color/sensor_red"
                    android:textSize="80dp"
                    app:layout_constraintWidth_percent="0.64"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/humidity_title"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintHorizontal_bias="1"/>

            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/margin1"
            android:layout_width="0dp"
            android:layout_height="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/lo_sensor"
            app:layout_constraintWidth_percent="0.0260416667"
            />

        <TextView
            android:id="@+id/txt_datetime"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="2025-10-13 14:04"
            android:textColor="@color/white"
            android:fontFamily="@font/pretendard_medium"
            android:textSize="80dp"
            android:autoSizeTextType="uniform"
            android:autoSizeStepGranularity="1dp"
            android:maxLines="1"
            android:gravity="center"
            app:layout_constraintWidth_percent="0.1552083333333333"
            app:layout_constraintHeight_percent="0.41666666666666677"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/margin1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            />

        <View
            android:id="@+id/margin2"
            android:layout_width="0dp"
            android:layout_height="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/txt_datetime"
            app:layout_constraintWidth_percent="0.0260416667"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/margin2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintWidth_percent="0.1572916667"
            app:layout_constraintHeight_percent="0.5666666667">

            <kr.co.kworks.goodmorning.view.Switch
                android:id="@+id/switch_live"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.4304635762"
                app:layout_constraintHorizontal_bias="0"
                />

            <TextView
                android:id="@+id/txt_switch"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="영상라이브"
                android:textColor="@color/white"
                android:fontFamily="@font/pretendard_medium"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="center"
                app:layout_constraintWidth_percent="0.5033112583"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />


        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/margin_end"
            android:layout_width="0dp"
            android:layout_height="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1"
            app:layout_constraintWidth_percent="0.0145833333"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_exit"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/margin2"
            app:layout_constraintEnd_toStartOf="@id/margin_end"
            app:layout_constraintHorizontal_bias="1"
            app:layout_constraintWidth_percent="0.05"
            app:layout_constraintHeight_percent="0.8333333333">

            <ImageView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@drawable/icon_exit"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.6666666667"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintVertical_bias="0"
                />

            <TextView
                android:id="@+id/txt_exit"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="로그아웃"
                android:textColor="@color/white"
                android:fontFamily="@font/pretendard_medium"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="center_horizontal|bottom"
                app:layout_constraintWidth_percent="1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="1"
                />


        </androidx.constraintlayout.widget.ConstraintLayout>



    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>