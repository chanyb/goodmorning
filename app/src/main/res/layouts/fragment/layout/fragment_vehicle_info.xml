<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lo_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_header"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.1"
            app:layout_constraintVertical_bias="0" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_info"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/lo_header"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.35"
            app:layout_constraintHeight_percent="0.7633333333333333"
            app:layout_constraintVertical_bias="0.4"
            app:layout_constraintHorizontal_bias="0.0739583333333333">

            <View
                android:id="@+id/start_padding"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintWidth_percent="0.0920245398773006"
                />

            <View
                android:id="@+id/end_padding"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1"
                app:layout_constraintWidth_percent="0.0920245398773006"
                />

            <View
                android:id="@+id/guide"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintWidth_percent="0.0920245398773006"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

            <View
                android:id="@+id/lo_vehicle_number"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_10_transparent_white_10"
                app:layout_constraintHeight_percent="0.148471615720524"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/lo_device_ip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                />

            <View
                android:id="@+id/lo_device_ip"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_10_transparent_white_10"
                app:layout_constraintHeight_percent="0.148471615720524"
                app:layout_constraintTop_toBottomOf="@id/lo_vehicle_number"
                app:layout_constraintBottom_toTopOf="@id/lo_sensor_ip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

            <View
                android:id="@+id/lo_sensor_ip"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_10_transparent_white_10"
                app:layout_constraintHeight_percent="0.148471615720524"
                app:layout_constraintTop_toBottomOf="@id/lo_device_ip"
                app:layout_constraintBottom_toTopOf="@id/lo_cctv_ip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

            <View
                android:id="@+id/lo_cctv_ip"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_10_transparent_white_10"
                app:layout_constraintHeight_percent="0.148471615720524"
                app:layout_constraintTop_toBottomOf="@id/lo_sensor_ip"
                app:layout_constraintBottom_toTopOf="@id/lo_ai_device_ip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

            <View
                android:id="@+id/lo_ai_device_ip"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_10_transparent_white_10"
                app:layout_constraintHeight_percent="0.148471615720524"
                app:layout_constraintTop_toBottomOf="@id/lo_cctv_ip"
                app:layout_constraintBottom_toTopOf="@id/lo_board_ip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

            <View
                android:id="@+id/lo_board_ip"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_10_transparent_white_10"
                app:layout_constraintHeight_percent="0.148471615720524"
                app:layout_constraintTop_toBottomOf="@id/lo_ai_device_ip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="1"
                />

            <TextView
                android:id="@+id/txt_vehicle_number_title"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="차량번호"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_bold"
                android:gravity="center_vertical"
                app:layout_constraintHeight_percent="0.0611353711790393"
                app:layout_constraintTop_toTopOf="@id/lo_vehicle_number"
                app:layout_constraintBottom_toBottomOf="@id/lo_vehicle_number"
                app:layout_constraintStart_toEndOf="@id/start_padding"
                app:layout_constraintEnd_toStartOf="@id/guide"
                />

            <TextView
                android:id="@+id/txt_device_ip_title"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="디바이스 IP"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_bold"
                android:gravity="center_vertical"
                app:layout_constraintHeight_percent="0.0611353711790393"
                app:layout_constraintTop_toTopOf="@id/lo_device_ip"
                app:layout_constraintBottom_toBottomOf="@id/lo_device_ip"
                app:layout_constraintStart_toEndOf="@id/start_padding"
                app:layout_constraintEnd_toStartOf="@id/guide"
                />

            <TextView
                android:id="@+id/txt_sensor_ip_title"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="기상센서 IP"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_bold"
                android:gravity="center_vertical"
                app:layout_constraintHeight_percent="0.0611353711790393"
                app:layout_constraintTop_toTopOf="@id/lo_sensor_ip"
                app:layout_constraintBottom_toBottomOf="@id/lo_sensor_ip"
                app:layout_constraintStart_toEndOf="@id/start_padding"
                app:layout_constraintEnd_toStartOf="@id/guide"
                />

            <TextView
                android:id="@+id/txt_ai_device_ip_title"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="AI 디바이스 IP"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_bold"
                android:gravity="center_vertical"
                app:layout_constraintHeight_percent="0.0611353711790393"
                app:layout_constraintTop_toTopOf="@id/lo_ai_device_ip"
                app:layout_constraintBottom_toBottomOf="@id/lo_ai_device_ip"
                app:layout_constraintStart_toEndOf="@id/start_padding"
                app:layout_constraintEnd_toStartOf="@id/guide"
                />

            <TextView
                android:id="@+id/txt_board_ip_title"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="중계보드 IP"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_bold"
                android:gravity="center_vertical"
                app:layout_constraintHeight_percent="0.0611353711790393"
                app:layout_constraintTop_toTopOf="@id/lo_board_ip"
                app:layout_constraintBottom_toBottomOf="@id/lo_board_ip"
                app:layout_constraintStart_toEndOf="@id/start_padding"
                app:layout_constraintEnd_toStartOf="@id/guide"
                />

            <TextView
                android:id="@+id/txt_cctv_ip_title"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="CCTV IP"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_bold"
                android:gravity="center_vertical"
                app:layout_constraintHeight_percent="0.0611353711790393"
                app:layout_constraintTop_toTopOf="@id/lo_cctv_ip"
                app:layout_constraintBottom_toBottomOf="@id/lo_cctv_ip"
                app:layout_constraintStart_toEndOf="@id/start_padding"
                app:layout_constraintEnd_toStartOf="@id/guide"
                />

            <TextView
                android:id="@+id/txt_vehicle_number_body"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="차량번호"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_medium"
                android:gravity="center_vertical"
                app:layout_constraintHeight_percent="0.0611353711790393"
                app:layout_constraintTop_toTopOf="@id/lo_vehicle_number"
                app:layout_constraintBottom_toBottomOf="@id/lo_vehicle_number"
                app:layout_constraintStart_toEndOf="@id/guide"
                app:layout_constraintEnd_toStartOf="@id/end_padding"
                />

            <TextView
                android:id="@+id/txt_device_ip_body"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="디바이스 IP"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_medium"
                android:gravity="center_vertical"
                app:layout_constraintHeight_percent="0.0611353711790393"
                app:layout_constraintTop_toTopOf="@id/lo_device_ip"
                app:layout_constraintBottom_toBottomOf="@id/lo_device_ip"
                app:layout_constraintStart_toEndOf="@id/guide"
                app:layout_constraintEnd_toStartOf="@id/end_padding"
                />

            <TextView
                android:id="@+id/txt_sensor_ip_body"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="기상센서 IP"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_medium"
                android:gravity="center_vertical"
                app:layout_constraintHeight_percent="0.0611353711790393"
                app:layout_constraintTop_toTopOf="@id/lo_sensor_ip"
                app:layout_constraintBottom_toBottomOf="@id/lo_sensor_ip"
                app:layout_constraintStart_toEndOf="@id/guide"
                app:layout_constraintEnd_toStartOf="@id/end_padding"
                />

            <TextView
                android:id="@+id/txt_cctv_ip_body"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="CCTV IP"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_medium"
                android:gravity="center_vertical"
                app:layout_constraintHeight_percent="0.0611353711790393"
                app:layout_constraintTop_toTopOf="@id/lo_cctv_ip"
                app:layout_constraintBottom_toBottomOf="@id/lo_cctv_ip"
                app:layout_constraintStart_toEndOf="@id/guide"
                app:layout_constraintEnd_toStartOf="@id/end_padding"
                />

            <TextView
                android:id="@+id/txt_ai_device_ip_body"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="AI 디바이스 IP"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_medium"
                android:gravity="center_vertical"
                app:layout_constraintHeight_percent="0.0611353711790393"
                app:layout_constraintTop_toTopOf="@id/lo_ai_device_ip"
                app:layout_constraintBottom_toBottomOf="@id/lo_ai_device_ip"
                app:layout_constraintStart_toEndOf="@id/guide"
                app:layout_constraintEnd_toStartOf="@id/end_padding"
                />

            <TextView
                android:id="@+id/txt_board_ip_body"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="중계보드 IP"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_medium"
                android:gravity="center_vertical"
                app:layout_constraintHeight_percent="0.0611353711790393"
                app:layout_constraintTop_toTopOf="@id/lo_board_ip"
                app:layout_constraintBottom_toBottomOf="@id/lo_board_ip"
                app:layout_constraintStart_toEndOf="@id/guide"
                app:layout_constraintEnd_toStartOf="@id/end_padding"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_water"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.35"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintVertical_bias="0.5"
            app:layout_constraintHorizontal_bias="0.9">

            <com.scichart.charting.visuals.SciPieChartSurface
                android:id="@+id/surface"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <kr.co.kworks.goodmorning.view.Circle
                android:id="@+id/circle_remain"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:color="@color/background"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.4"
                app:layout_constraintDimensionRatio="1:1"
                />

            <TextView
                android:id="@+id/txt_remain"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="300L"
                android:textSize="80dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_bold"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="@id/circle_remain"
                app:layout_constraintBottom_toBottomOf="@id/circle_remain"
                app:layout_constraintStart_toStartOf="@id/circle_remain"
                app:layout_constraintEnd_toEndOf="@id/circle_remain"
                app:layout_constraintWidth_percent="0.25"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/txt_total"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="물 탱크 용량: 500L"
            android:textSize="80dp"
            android:textColor="@color/white"
            android:autoSizeTextType="uniform"
            android:autoSizeStepGranularity="1dp"
            android:maxLines="1"
            android:fontFamily="@font/pretendard_bold"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/lo_water"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/lo_water"
            app:layout_constraintEnd_toEndOf="@id/lo_water"
            app:layout_constraintWidth_percent="0.1979166666666667"
            app:layout_constraintHeight_percent="0.06"
            app:layout_constraintVertical_bias="0.1"
            />

        

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>