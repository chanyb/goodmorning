<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lo_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/background_edge_10_transparent_white_10">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.525"
            app:layout_constraintHeight_percent="0.416"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.3767123287671233">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_edit_car_number"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_10_black000219"
                app:layout_constraintWidth_percent="0.6134969325153374"
                app:layout_constraintHeight_percent="0.2692307692307692"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintHorizontal_bias="1">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/padding_start"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.1"
                    />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/padding_end"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.9"
                    />


                <EditText
                    android:id="@+id/edit_vehicle_number"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@null"
                    android:textColor="@color/white"
                    android:textSize="28dp"
                    android:gravity="center_vertical"
                    android:autoSizeTextType="uniform"
                    android:inputType="text"
                    android:maxLines="1"
                    android:text="99소9999"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="@id/padding_start"
                    app:layout_constraintEnd_toEndOf="@id/padding_end"
                    app:layout_constraintHeight_percent="0.5"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/car_number_margin_bottom"
                android:layout_width="1dp"
                android:layout_height="0dp"
                app:layout_constraintHeight_percent="0.0961538461538462"
                app:layout_constraintTop_toBottomOf="@id/lo_edit_car_number"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_edit_device_code"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_10_black000219"
                app:layout_constraintWidth_percent="0.6134969325153374"
                app:layout_constraintHeight_percent="0.2692307692307692"
                app:layout_constraintTop_toBottomOf="@id/car_number_margin_bottom"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintHorizontal_bias="1">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/padding_start_2"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.1"
                    />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/padding_end_2"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.9"
                    />


                <EditText
                    android:id="@+id/edit_device_code"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@null"
                    android:textColor="@color/white"
                    android:textSize="28dp"
                    android:gravity="center_vertical"
                    android:autoSizeTextType="uniform"
                    android:maxLines="1"
                    android:text="A000017"
                    android:inputType="text"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="@id/padding_start_2"
                    app:layout_constraintEnd_toEndOf="@id/padding_end_2"
                    app:layout_constraintHeight_percent="0.5"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/device_code_margin_bottom"
                android:layout_width="1dp"
                android:layout_height="0dp"
                app:layout_constraintHeight_percent="0.0961538461538462"
                app:layout_constraintTop_toBottomOf="@id/lo_edit_device_code"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_edit_car_code"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_10_black000219"
                app:layout_constraintWidth_percent="0.6134969325153374"
                app:layout_constraintHeight_percent="0.2692307692307692"
                app:layout_constraintTop_toBottomOf="@id/device_code_margin_bottom"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintHorizontal_bias="1">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/padding_start_3"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.1"
                    />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/padding_end_3"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.9"
                    />


                <EditText
                    android:id="@+id/edit_vehicle_code"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@null"
                    android:textColor="@color/white"
                    android:textSize="28dp"
                    android:gravity="center_vertical"
                    android:autoSizeTextType="uniform"
                    android:maxLines="1"
                    android:text="C00010"
                    android:inputType="text"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="@id/padding_start_3"
                    app:layout_constraintEnd_toEndOf="@id/padding_end_3"
                    app:layout_constraintHeight_percent="0.5"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>


            <TextView
                android:id="@+id/txt_car_number_title"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:text="차량번호"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:fontFamily="@font/pretendard_bold"
                app:layout_constraintHeight_percent="0.1346153846153846"
                app:layout_constraintTop_toTopOf="@id/lo_edit_car_number"
                app:layout_constraintBottom_toBottomOf="@id/lo_edit_car_number"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                />

            <TextView
                android:id="@+id/txt_device_code_title"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:text="디바이스 코드"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:fontFamily="@font/pretendard_bold"
                app:layout_constraintHeight_percent="0.1346153846153846"
                app:layout_constraintTop_toTopOf="@id/lo_edit_device_code"
                app:layout_constraintBottom_toBottomOf="@id/lo_edit_device_code"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                />

            <TextView
                android:id="@+id/txt_car_code_title"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:text="차 코드"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:fontFamily="@font/pretendard_bold"
                app:layout_constraintHeight_percent="0.1346153846153846"
                app:layout_constraintTop_toTopOf="@id/lo_edit_car_code"
                app:layout_constraintBottom_toBottomOf="@id/lo_edit_car_code"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                />


        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToOutline="true"
            android:background="@drawable/background_edge_10_white"
            android:textSize="26dp"
            android:gravity="center"
            android:maxLines="1"
            android:text="저장"
            android:textColor="@color/black"
            android:fontFamily="@font/pretendard_bold"
            app:layout_constraintWidth_percent="0.2"
            app:layout_constraintHeight_percent="0.08"
            app:layout_constraintVertical_bias="0.9130434782608696"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>