<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lo_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">


        <TextView
            android:id="@+id/text1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="@string/str_step_1_text_1"
            android:fontFamily="@font/pretendard_bold"
            android:textColor="@color/white"
            android:textSize="80dp"
            android:autoSizeTextType="uniform"
            android:autoSizeStepGranularity="1dp"
            android:maxLines="1"
            app:layout_constraintWidth_percent="0.2"
            app:layout_constraintHeight_percent="0.065"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.0833333333333333"
            />

        <TextView
            android:id="@+id/text2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="@string/str_step_1_text_2"
            android:fontFamily="@font/pretendard_medium"
            android:textColor="@color/gray_abacb3"
            android:textSize="80dp"
            android:autoSizeTextType="uniform"
            android:autoSizeStepGranularity="1dp"
            android:maxLines="2"
            android:lineSpacingMultiplier="1.5"
            app:layout_constraintWidth_percent="0.69375"
            app:layout_constraintHeight_percent="0.1333333333333333"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.2316666666666667"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_code"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.5760416666666667"
            app:layout_constraintHeight_percent="0.18"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.5033333333333333">

            <TextView
                android:id="@+id/title"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="@string/str_step_1_input_title"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/white"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="2"
                app:layout_constraintTop_toTopOf="@id/lo_input"
                app:layout_constraintBottom_toBottomOf="@id/lo_input"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintWidth_percent="0.2061482820976492"
                app:layout_constraintHeight_percent="0.3611111111111111"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_input"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintWidth_percent="0.7576853526220615"
                app:layout_constraintHeight_percent="0.6388888888888889">

                <EditText
                    android:id="@+id/edit1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/background_edge_20_transparent_white_10"
                    android:textColor="@color/white"
                    android:textSize="40dp"
                    android:gravity="center"
                    android:autoSizeTextType="uniform"
                    android:maxLines="1"
                    app:layout_constraintWidth_percent="0.2386634844868735"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    />

                <EditText
                    android:id="@+id/edit2"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/background_edge_20_transparent_white_10"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:textSize="40dp"
                    android:maxLines="1"
                    app:layout_constraintWidth_percent="0.2386634844868735"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/edit1"
                    app:layout_constraintEnd_toStartOf="@id/edit3"
                    />

                <EditText
                    android:id="@+id/edit3"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/background_edge_20_transparent_white_10"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="40dp"
                    android:maxLines="1"
                    app:layout_constraintWidth_percent="0.2601431980906921"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1"
                    />

                <View
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:background="@color/gray_9D9EB3"
                    app:layout_constraintWidth_percent="0.035799522673031"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/edit1"
                    app:layout_constraintEnd_toStartOf="@id/edit2"
                    />

                <View
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:background="@color/gray_9D9EB3"
                    app:layout_constraintWidth_percent="0.035799522673031"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/edit2"
                    app:layout_constraintEnd_toStartOf="@id/edit3"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/example"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="@string/str_step_1_example"
                android:fontFamily="@font/pretendard_medium"
                android:textColor="@color/gray_9D9EB3"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                app:layout_constraintWidth_percent="0.294755877034358"
                app:layout_constraintHeight_percent="0.2314814814814815"
                app:layout_constraintStart_toStartOf="@id/lo_input"
                app:layout_constraintTop_toBottomOf="@id/lo_input"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_btn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.2104166666666667"
            app:layout_constraintHeight_percent="0.0966666666666667"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.92"
            android:background="@drawable/background_edge_30_transparent_outline_green"
            android:clipToOutline="true">

            <TextView
                android:id="@+id/txt_btn"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="@string/str_step_1_btn"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/communicate_green"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="center"
                app:layout_constraintWidth_percent="0.3069306930693069"
                app:layout_constraintHeight_percent="0.5862068965517241"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>