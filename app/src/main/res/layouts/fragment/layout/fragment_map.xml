<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lo_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_header"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.1"
            app:layout_constraintVertical_bias="0" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/map"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:name="com.naver.maps.map.MapFragment"
            app:layout_constraintTop_toBottomOf="@id/lo_header"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <View
            android:id="@+id/margin_left"
            android:layout_width="0dp"
            android:layout_height="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.0208333333"
            app:layout_constraintHorizontal_bias="0"
            />

        <View
            android:id="@+id/margin_top"
            android:layout_width="1dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/lo_header"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.0592592593"
            app:layout_constraintVertical_bias="0"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_side_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintWidth_percent="0.2083333333333333"
            app:layout_constraintTop_toBottomOf="@id/margin_top"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/margin_left"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0104166666666667"
            app:layout_constraintVertical_bias="0">

            <!-- 내 위치 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_my_location"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_30_transparent_black_80"
                android:visibility="gone"
                app:layout_constraintDimensionRatio="1:0.27"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                android:clipToOutline="true">

                <TextView
                    android:id="@+id/txt_my_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:text="@string/str_my_location"
                    android:fontFamily="@font/pretendard_medium"
                    android:textSize="30dp"
                    android:textColor="@color/gray_81838f"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 진화헬기 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_heli_list"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_30_transparent_black_80"
                android:layout_marginTop="10dp"
                app:layout_constraintDimensionRatio="1:0.27"
                app:layout_constraintTop_toBottomOf="@id/btn_my_location"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                android:clipToOutline="true">

                <View
                    android:id="@+id/txt_heli_margin"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    app:layout_constraintWidth_percent="0.1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    />

                <TextView
                    android:id="@+id/txt_helli_list"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/txt_heli_margin"
                    android:text="진화헬기"
                    android:fontFamily="@font/pretendard_medium"
                    android:textSize="30dp"
                    android:textColor="@color/gray_81838f"
                    />

                <View
                    android:id="@+id/guide_badge_helli"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    app:layout_constraintWidth_percent="0.035"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    />

                <kr.co.kworks.goodmorning.view.Circle
                    android:id="@+id/badge_helli"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:color="@color/gray_81838f"
                    app:layout_constraintHeight_percent="0.7407407407"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/guide_badge_helli"
                    />

                <TextView
                    android:id="@+id/txt_badge_helli"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:text="OFF"
                    android:textColor="@color/black"
                    android:textSize="80dp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeStepGranularity="1dp"
                    android:maxLines="1"
                    android:fontFamily="@font/pretendard_bold"
                    android:gravity="center"
                    app:layout_constraintStart_toStartOf="@id/badge_helli"
                    app:layout_constraintEnd_toEndOf="@id/badge_helli"
                    app:layout_constraintTop_toTopOf="@id/badge_helli"
                    app:layout_constraintBottom_toBottomOf="@id/badge_helli"
                    app:layout_constraintHeight_percent="0.4074074074"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 다목적 차량 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_vehicle_list"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_30_transparent_black_80"
                android:layout_marginTop="10dp"
                app:layout_constraintDimensionRatio="1:0.27"
                app:layout_constraintTop_toBottomOf="@id/btn_heli_list"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                android:clipToOutline="true">

                <View
                    android:id="@+id/txt_vehicle_margin"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    app:layout_constraintWidth_percent="0.1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    />

                <TextView
                    android:id="@+id/txt_vehicle_list"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/txt_vehicle_margin"
                    android:text="다목적 차량"
                    android:fontFamily="@font/pretendard_medium"
                    android:textSize="30dp"
                    android:textColor="@color/gray_81838f"
                    />

                <View
                    android:id="@+id/guide_badge_vehicle"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    app:layout_constraintWidth_percent="0.035"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    />

                <kr.co.kworks.goodmorning.view.Circle
                    android:id="@+id/badge_vehicle"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:color="@color/gray_81838f"
                    app:layout_constraintHeight_percent="0.7407407407"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/guide_badge_vehicle"
                    />

                <TextView
                    android:id="@+id/txt_badge_vehicle"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:text="OFF"
                    android:textColor="@color/black"
                    android:textSize="80dp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeStepGranularity="1dp"
                    android:maxLines="1"
                    android:fontFamily="@font/pretendard_bold"
                    android:gravity="center"
                    app:layout_constraintStart_toStartOf="@id/badge_vehicle"
                    app:layout_constraintEnd_toEndOf="@id/badge_vehicle"
                    app:layout_constraintTop_toTopOf="@id/badge_vehicle"
                    app:layout_constraintBottom_toBottomOf="@id/badge_vehicle"
                    app:layout_constraintHeight_percent="0.4074074074"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 진화요원 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_man_list"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_30_transparent_black_80"
                android:layout_marginTop="10dp"
                app:layout_constraintDimensionRatio="1:0.27"
                app:layout_constraintTop_toBottomOf="@id/btn_vehicle_list"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                android:clipToOutline="true">

                <View
                    android:id="@+id/txt_man_margin"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    app:layout_constraintWidth_percent="0.1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    />

                <TextView
                    android:id="@+id/txt_man_list"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/txt_man_margin"
                    android:text="진화요원"
                    android:fontFamily="@font/pretendard_medium"
                    android:textSize="30dp"
                    android:textColor="@color/gray_81838f"
                    />

<!--                <View-->
<!--                    android:id="@+id/guide_badge_man"-->
<!--                    android:layout_width="0dp"-->
<!--                    android:layout_height="1dp"-->
<!--                    app:layout_constraintWidth_percent="0.035"-->
<!--                    app:layout_constraintTop_toTopOf="parent"-->
<!--                    app:layout_constraintBottom_toBottomOf="parent"-->
<!--                    app:layout_constraintEnd_toEndOf="parent"-->
<!--                    />-->

<!--                <kr.view.vehicle.forest.co.Circle-->
<!--                    android:layout_width="0dp"-->
<!--                    android:layout_height="0dp"-->
<!--                    app:color="@color/gray_81838f"-->
<!--                    app:layout_constraintHeight_percent="0.7407407407"-->
<!--                    app:layout_constraintDimensionRatio="1:1"-->
<!--                    app:layout_constraintTop_toTopOf="parent"-->
<!--                    app:layout_constraintBottom_toBottomOf="parent"-->
<!--                    app:layout_constraintEnd_toStartOf="@id/guide_badge_man"-->
<!--                    />-->

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/txt_man_margin"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:text="서비스준비중"
                    android:textColor="@color/gray_81838f"
                    android:textSize="80dp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeStepGranularity="1dp"
                    android:maxLines="1"
                    app:layout_constraintWidth_percent="0.345"
                    app:layout_constraintHeight_percent="0.3461538462"
                    app:layout_constraintHorizontal_bias="0.9"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/lo_distance_top_margin"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/lo_header"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.03"
            app:layout_constraintVertical_bias="0"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_distance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/background_edge_10_transparent_black_90"
            app:layout_constraintTop_toBottomOf="@id/lo_distance_top_margin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.1083333333"
            app:layout_constraintHorizontal_bias="0.98"
            app:layout_constraintVertical_bias="0">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_distance_selected"
                android:layout_width="0dp"
                android:layout_height="50dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.8">

                <TextView
                    android:id="@+id/txt_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    android:text="10"
                    android:textSize="20dp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/pretendard_semibold"
                    />

                <TextView
                    android:id="@+id/tt_distance_postfix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/txt_distance"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    android:text="km 이내"
                    android:textSize="20dp"
                    android:textColor="@color/white"
                    />

                <kr.co.kworks.goodmorning.view.Triangle
                    android:id="@+id/lo_distance_triangle"
                    android:layout_width="8dp"
                    android:layout_height="6dp"
                    app:color="@color/white"
                    android:rotation="180"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_distance_type1"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/lo_distance_selected"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.8">


            <TextView
                    android:id="@+id/txt_distance_type1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    android:text="10"
                    android:textSize="20dp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/pretendard_semibold"
                    />

                <TextView
                    android:id="@+id/tt_distance_type1_postfix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/txt_distance_type1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    android:text="km 이내"
                    android:textSize="20dp"
                    android:textColor="@color/white"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_distance_type2"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/lo_distance_type1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.8">

                <TextView
                    android:id="@+id/txt_distance_type2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    android:text="20"
                    android:textSize="20dp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/pretendard_semibold"
                    />

                <TextView
                    android:id="@+id/tt_distance_type2_postfix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/txt_distance_type2"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    android:text="km 이내"
                    android:textSize="20dp"
                    android:textColor="@color/white"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_distance_type3"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/lo_distance_type2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.8">

                <TextView
                    android:id="@+id/txt_distance_type3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    android:text="500"
                    android:textSize="20dp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/pretendard_semibold"
                    />

                <TextView
                    android:id="@+id/tt_distance_type3_postfix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/txt_distance_type3"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    android:text="km 이내"
                    android:textSize="20dp"
                    android:textColor="@color/white"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/fragment_video"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/lo_header"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.5"
            app:layout_constraintHorizontal_bias="1"
            />

        <include
            android:id="@+id/dialog"
            layout="@layout/item_dialog" />

        <include
            android:id="@+id/video_relay_confirm"
            layout="@layout/item_video_relay_confirm" />

        <include
            android:id="@+id/exit_confirm"
            layout="@layout/item_exit_confirm" />

    </androidx.constraintlayout.widget.ConstraintLayout>


</layout>