<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lo_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">


        <TextView
            android:id="@+id/text1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="@string/str_step_3_text_1"
            android:fontFamily="@font/pretendard_bold"
            android:textColor="@color/white"
            android:textSize="80dp"
            android:autoSizeTextType="uniform"
            android:autoSizeStepGranularity="1dp"
            android:maxLines="1"
            app:layout_constraintWidth_percent="0.2"
            app:layout_constraintHeight_percent="0.065"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.0833333333333333"
            />

        <TextView
            android:id="@+id/text2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str"
            android:fontFamily="@font/pretendard_medium"
            android:textColor="@color/gray_abacb3"
            android:textSize="30dp"
            android:lineSpacingMultiplier="1.5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.4"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_btn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.2104166666666667"
            app:layout_constraintHeight_percent="0.0966666666666667"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.92"
            android:background="@drawable/background_edge_30_transparent_outline_green"
            android:clipToOutline="true">

            <TextView
                android:id="@+id/txt_btn"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="@string/str_step_2_btn"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/communicate_green"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="center"
                app:layout_constraintWidth_percent="0.3069306930693069"
                app:layout_constraintHeight_percent="0.5862068965517241"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>