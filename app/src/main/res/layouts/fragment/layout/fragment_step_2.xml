<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lo_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_content"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.6">

            <View
                android:id="@+id/guide_1"
                android:layout_width="0dp"
                android:layout_height="1dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.1875"
                app:layout_constraintWidth_percent="0.05"
                />

            <TextView
                android:id="@+id/txt_device_code"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/str_step_2_text_1"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/white"
                android:textSize="50dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                app:layout_constraintTop_toTopOf="@id/lo_device_number"
                app:layout_constraintBottom_toBottomOf="@id/lo_device_number"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/guide_1"
                app:layout_constraintHorizontal_bias="0"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_device_number"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/guide_1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1"
                app:layout_constraintVertical_bias="0.2"
                app:layout_constraintHeight_percent="0.115">

                <EditText
                    android:id="@+id/edit1_1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/background_edge_20_transparent_white_10"
                    android:textColor="@color/white"
                    android:textSize="40dp"
                    android:gravity="center"
                    android:autoSizeTextType="uniform"
                    android:maxLines="1"
                    app:layout_constraintWidth_percent="0.2386634844868735"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    />

                <EditText
                    android:id="@+id/edit1_2"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/background_edge_20_transparent_white_10"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:textSize="40dp"
                    android:maxLines="1"
                    android:inputType="numberDecimal"
                    app:layout_constraintWidth_percent="0.6540178571"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/edit1_1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1"
                    />

                <View
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:background="@color/gray_9D9EB3"
                    app:layout_constraintWidth_percent="0.035799522673031"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/edit1_1"
                    app:layout_constraintEnd_toStartOf="@id/edit1_2"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/margin1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@id/lo_device_number"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHeight_percent="0.01"
                app:layout_constraintVertical_bias="0"
                />

            <TextView
                android:id="@+id/example1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/str_step_2_text_2"
                android:fontFamily="@font/pretendard_medium"
                android:textColor="@color/gray_9D9EB3"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                app:layout_constraintWidth_percent="0.294755877034358"
                app:layout_constraintHeight_percent="0.2314814814814815"
                app:layout_constraintTop_toBottomOf="@id/margin1"
                app:layout_constraintStart_toStartOf="@id/lo_device_number"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                />


            <TextView
                android:id="@+id/txt_vehicle_number"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/str_step_2_text_3"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/white"
                android:textSize="50dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                app:layout_constraintTop_toTopOf="@id/lo_vehicle_number"
                app:layout_constraintBottom_toBottomOf="@id/lo_vehicle_number"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/guide_1"
                app:layout_constraintHorizontal_bias="0"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_vehicle_number"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/guide_1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1"
                app:layout_constraintVertical_bias="0.5"
                app:layout_constraintHeight_percent="0.115">

                <EditText
                    android:id="@+id/edit2"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/background_edge_20_transparent_white_10"
                    android:textColor="@color/white"
                    android:textSize="40dp"
                    android:gravity="center_vertical"
                    android:autoSizeTextType="uniform"
                    android:maxLines="1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/margin2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@id/lo_vehicle_number"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHeight_percent="0.01"
                app:layout_constraintVertical_bias="0"
                />

            <TextView
                android:id="@+id/example2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/str_step_2_text_4"
                android:fontFamily="@font/pretendard_medium"
                android:textColor="@color/gray_9D9EB3"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                app:layout_constraintWidth_percent="0.294755877034358"
                app:layout_constraintHeight_percent="0.2314814814814815"
                app:layout_constraintTop_toBottomOf="@id/margin2"
                app:layout_constraintStart_toStartOf="@id/lo_vehicle_number"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_btn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.2104166666666667"
            app:layout_constraintHeight_percent="0.0966666666666667"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.92"
            android:background="@drawable/background_edge_30_transparent_outline_green"
            android:clipToOutline="true">

            <TextView
                android:id="@+id/txt_btn"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="@string/str_step_2_btn"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/communicate_green"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="center"
                app:layout_constraintWidth_percent="0.3069306930693069"
                app:layout_constraintHeight_percent="0.5862068965517241"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <include
            android:id="@+id/dialog"
            layout="@layout/item_dialog" />

        <include
            android:id="@+id/dialog_force"
            layout="@layout/item_vehicle_force_mapping" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>