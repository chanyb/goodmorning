<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lo_main"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:paddingBottom="15dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_top"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="15dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:background="@drawable/background_edge_transparent_10"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0"
            app:layout_constraintHeight_percent="0.1">

            <View
                android:id="@+id/guide_lo_top_1"
                android:layout_width="1dp"
                android:layout_height="1dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.05"
                />

            <View
                android:id="@+id/guide_lo_top_1_1"
                android:layout_width="1dp"
                android:layout_height="1dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.09"
                />


            <View
                android:id="@+id/guide_lo_top_2"
                android:layout_width="2dp"
                android:layout_height="0dp"
                android:background="@color/white_10"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHeight_percent="0.65"
                />

            <View
                android:id="@+id/guide_lo_top_3"
                android:layout_width="1dp"
                android:layout_height="1dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.55"
                />

            <View
                android:id="@+id/guide_lo_top_4"
                android:layout_width="1dp"
                android:layout_height="1dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.95"
                />

            <View
                android:id="@+id/led"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/video_play_selector"
                app:layout_constraintTop_toTopOf="@id/guide_lo_top_1"
                app:layout_constraintBottom_toBottomOf="@id/guide_lo_top_1"
                app:layout_constraintStart_toStartOf="@id/guide_lo_top_1"
                app:layout_constraintWidth_percent="0.02"
                app:layout_constraintDimensionRatio="1:1"
                />

            <TextView
                android:id="@+id/txt_is_play"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/str"
                android:textSize="34dp"
                android:textColor="@color/white"
                android:fontFamily="@font/pretendard_semibold"
                android:autoSizeTextType="uniform"
                app:layout_constraintTop_toTopOf="@id/guide_lo_top_1_1"
                app:layout_constraintBottom_toBottomOf="@id/guide_lo_top_1_1"
                app:layout_constraintStart_toStartOf="@id/guide_lo_top_1_1"
                app:layout_constraintEnd_toEndOf="@id/guide_lo_top_2"
                />

            <TextView
                android:id="@+id/txt_temperature_title"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="@string/str"
                android:textSize="30dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:gravity="center_vertical"
                android:layout_marginEnd="10dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/guide_lo_top_3"
                app:layout_constraintEnd_toStartOf="@id/txt_temperature_body"
                />

            <TextView
                android:id="@+id/txt_temperature_body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str"
                android:textSize="34dp"
                android:textColor="@color/white"
                android:fontFamily="@font/pretendard_semibold"
                app:layout_constraintTop_toTopOf="@id/guide_lo_top_4"
                app:layout_constraintBottom_toBottomOf="@id/guide_lo_top_4"
                app:layout_constraintEnd_toEndOf="@id/guide_lo_top_4"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_video"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/background_edge_transparent_10"
            android:clipToOutline="true"
            app:layout_constraintTop_toBottomOf="@id/lo_top"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="1:0.56">

            <androidx.media3.ui.PlayerView
                android:id="@+id/player_view"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="visible"
                app:surface_type="surface_view"
                app:show_buffering="when_playing"
                app:use_controller="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_no_video"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@color/black"
                app:layout_constraintTop_toTopOf="@id/player_view"
                app:layout_constraintBottom_toBottomOf="@id/player_view"
                app:layout_constraintStart_toStartOf="@id/player_view"
                app:layout_constraintEnd_toEndOf="@id/player_view">

                <View
                    android:id="@+id/no_video_background"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/background_edge_line_gray_aaa"
                    app:layout_constraintWidth_percent="0.142"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintDimensionRatio="5:3"
                    app:layout_constraintVertical_bias="0.4"
                    />

                <kr.co.kworks.goodmorning.view.Triangle
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:rotation="90"
                    app:color="@color/gray_aaa"
                    app:layout_constraintWidth_percent="0.025"
                    app:layout_constraintTop_toTopOf="@id/no_video_background"
                    app:layout_constraintBottom_toBottomOf="@id/no_video_background"
                    app:layout_constraintStart_toStartOf="@id/no_video_background"
                    app:layout_constraintEnd_toEndOf="@id/no_video_background"
                    app:layout_constraintDimensionRatio="1:1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/fragment_main_bottom_no_video"
                    android:textSize="24dp"
                    android:textColor="@color/gray_aaa"
                    app:layout_constraintTop_toBottomOf="@id/no_video_background"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintVertical_bias="0"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_pad"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@id/lo_video"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <kr.co.kworks.goodmorning.view.RadialPadView
                android:id="@+id/pad"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/radial_pad_background"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                />

            <kr.co.kworks.goodmorning.view.Triangle
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="@id/pad"
                app:layout_constraintBottom_toBottomOf="@id/pad"
                app:layout_constraintStart_toStartOf="@id/pad"
                app:layout_constraintEnd_toEndOf="@id/pad"
                app:layout_constraintVertical_bias="0.1"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintWidth_percent="0.03"
                />

            <kr.co.kworks.goodmorning.view.Triangle
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="@id/pad"
                app:layout_constraintBottom_toBottomOf="@id/pad"
                app:layout_constraintStart_toStartOf="@id/pad"
                app:layout_constraintEnd_toEndOf="@id/pad"
                app:layout_constraintVertical_bias="0.9"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintWidth_percent="0.03"
                android:rotation="180"
                />

            <kr.co.kworks.goodmorning.view.Triangle
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="@id/pad"
                app:layout_constraintBottom_toBottomOf="@id/pad"
                app:layout_constraintStart_toStartOf="@id/pad"
                app:layout_constraintEnd_toEndOf="@id/pad"
                app:layout_constraintVertical_bias="0.5"
                app:layout_constraintHorizontal_bias="0.9"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintWidth_percent="0.03"
                android:rotation="90"
                />

            <kr.co.kworks.goodmorning.view.Triangle
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="@id/pad"
                app:layout_constraintBottom_toBottomOf="@id/pad"
                app:layout_constraintStart_toStartOf="@id/pad"
                app:layout_constraintEnd_toEndOf="@id/pad"
                app:layout_constraintVertical_bias="0.5"
                app:layout_constraintHorizontal_bias="0.1"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintWidth_percent="0.03"
                android:rotation="270"
                />

            <View
                android:id="@+id/radial_pad_foreground"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/radial_pad_foreground"
                app:layout_constraintTop_toTopOf="@id/pad"
                app:layout_constraintBottom_toBottomOf="@id/pad"
                app:layout_constraintStart_toStartOf="@id/pad"
                app:layout_constraintEnd_toEndOf="@id/pad"
                app:layout_constraintWidth_percent="0.15"
                app:layout_constraintDimensionRatio="1:1"
                />

            <kr.co.kworks.goodmorning.view.Circle
                android:id="@+id/radial_pad_center"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:color="@color/white"
                app:layout_constraintTop_toTopOf="@id/radial_pad_foreground"
                app:layout_constraintBottom_toBottomOf="@id/radial_pad_foreground"
                app:layout_constraintStart_toStartOf="@id/radial_pad_foreground"
                app:layout_constraintEnd_toEndOf="@id/radial_pad_foreground"
                app:layout_constraintWidth_percent="0.07"
                app:layout_constraintDimensionRatio="1:1"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>




    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>