<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_header"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.1"
            app:layout_constraintVertical_bias="0" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/map"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:name="com.naver.maps.map.MapFragment"
            app:layout_constraintTop_toBottomOf="@id/lo_header"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_recycler_view"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/background_edge_10_transparent_black_80"
            android:clipToOutline="true"
            app:layout_constraintWidth_percent="0.2604166666666667"
            app:layout_constraintHeight_percent="0.8666666666666667"
            app:layout_constraintTop_toBottomOf="@id/lo_header"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0104166666666667">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/recycler_view_header"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintHeight_percent="0.0884615384615385">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/pretendard_semibold"
                    android:gravity="center"
                    android:text="일자 시간"
                    android:textColor="@color/white"
                    android:textSize="20dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.0"
                    app:layout_constraintWidth_percent="0.65" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="상태"
                    android:textSize="20dp"
                    android:gravity="center"
                    android:fontFamily="@font/pretendard_semibold"
                    android:textColor="@color/white"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1"
                    app:layout_constraintWidth_percent="0.35"
                    />

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:background="@color/white_10"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintVertical_bias="1"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:orientation="vertical"
                android:scrollbars="vertical"
                android:fadeScrollbars="false"
                android:scrollbarThumbVertical="@color/white"
                tools:listitem="@layout/item_fire_list"
                app:layout_constraintTop_toBottomOf="@id/recycler_view_header"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/background_edge_10_transparent_black_80"
            android:clipToOutline="true"
            app:layout_constraintWidth_percent="0.6697916666666667"
            app:layout_constraintHeight_percent="0.08"
            app:layout_constraintTop_toTopOf="@id/lo_recycler_view"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.98"
            app:layout_constraintVertical_bias="0">

            <View
                android:id="@+id/status_margin_start"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintWidth_percent="0.02"
                />

            <View
                android:id="@+id/status_margin_end"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1"
                app:layout_constraintWidth_percent="0.02"
                />

            <View
                android:id="@+id/txt_standard_datetime_margin_end"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                app:layout_constraintStart_toEndOf="@id/txt_standard_datetime"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintWidth_percent="0.01"
                />

            <TextView
                android:id="@+id/txt_standard_datetime"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:textSize="22dp"
                android:textColor="@color/white"
                android:fontFamily="@font/pretendard_medium"
                android:gravity="center_vertical"
                app:layout_constraintWidth_percent="0.32"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/status_margin_start"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_status"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/txt_standard_datetime_margin_end"
                app:layout_constraintEnd_toStartOf="@id/status_margin_end">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/lo_fire_ing"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintWidth_percent="0.28"
                    app:layout_constraintHorizontal_bias="0">

                    <TextView
                        android:id="@+id/txt_fire_ing_title"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:textSize="22dp"
                        android:textColor="@color/red"
                        android:gravity="center"
                        android:text="진화중 "
                        android:fontFamily="@font/pretendard_medium"
                        app:layout_constraintWidth_percent="0.5242718446601942"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0"
                        />

                    <TextView
                        android:id="@+id/txt_fire_ing_body"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:text="999"
                        android:textColor="@color/red"
                        android:gravity="center_vertical"
                        android:fontFamily="@font/pretendard_bold"
                        android:textSize="33dp"
                        app:layout_constraintWidth_percent="0.4757281553398058"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="1"
                        />


                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- 진화완료 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/lo_fire_end"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    app:layout_constraintStart_toEndOf="@id/lo_fire_ing"
                    app:layout_constraintEnd_toStartOf="@id/lo_fire_finish"
                    app:layout_constraintWidth_percent="0.32">

                    <TextView
                        android:id="@+id/txt_fire_end_title"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:textSize="22dp"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:text="진화완료 "
                        android:fontFamily="@font/pretendard_medium"
                        app:layout_constraintWidth_percent="0.55"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0"
                        />

                    <TextView
                        android:id="@+id/txt_fire_end_body"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:text="999"
                        android:textColor="@color/white"
                        android:gravity="center_vertical"
                        android:fontFamily="@font/pretendard_bold"
                        android:textSize="33dp"
                        app:layout_constraintWidth_percent="0.45"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="1"
                        />


                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- 산불외종료 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/lo_fire_finish"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintWidth_percent="0.36"
                    app:layout_constraintHorizontal_bias="1">

                    <TextView
                        android:id="@+id/txt_fire_finish_title"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:textSize="22dp"
                        android:textColor="@color/communicate_green"
                        android:gravity="center"
                        android:fontFamily="@font/pretendard_medium"
                        android:text="산불외종료 "
                        app:layout_constraintWidth_percent="0.6"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0"
                        />

                    <TextView
                        android:id="@+id/txt_fire_finish_body"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:text="999"
                        android:textColor="@color/communicate_green"
                        android:gravity="center_vertical"
                        android:fontFamily="@font/pretendard_bold"
                        android:textSize="33dp"
                        app:layout_constraintWidth_percent="0.4"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="1"
                        />


                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>



        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>