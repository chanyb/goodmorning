<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lo_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/background_edge_10_transparent_white_10">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_data"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/left_margin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.08"
                android:orientation="vertical"
                />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/right_margin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.92"
                android:orientation="vertical"
                />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/top_margin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.08"
                android:orientation="horizontal"
                />

            <TextView
                android:id="@+id/txt_app_info"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="앱 정보"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_bold"
                app:layout_constraintWidth_percent="0.1061093247588424"
                app:layout_constraintHeight_percent="0.068"
                app:layout_constraintTop_toTopOf="@id/top_margin"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/left_margin"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintHorizontal_bias="0"
                />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/top_margin_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.178"
                android:orientation="horizontal"
                />

            <TextView
                android:id="@+id/txt_app_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="버전: v1.0.1"
                android:textSize="26dp"
                android:textColor="@color/white"
                app:layout_constraintTop_toTopOf="@id/top_margin_2"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/left_margin"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintHorizontal_bias="0"
                />

            <View
                android:id="@+id/txt_app_version_margin_end"
                android:layout_width="0dp"
                android:layout_height="1dp"
                app:layout_constraintTop_toTopOf="@id/txt_app_version"
                app:layout_constraintBottom_toBottomOf="@id/txt_app_version"
                app:layout_constraintStart_toEndOf="@id/txt_app_version"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.0401929260450161"
                app:layout_constraintHorizontal_bias="0"
                />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/top_margin_2_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.258"
                android:orientation="horizontal"
                />

            <TextView
                android:id="@+id/txt_app_version_recent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="최신 소프트웨어 입니다."
                android:textSize="26dp"
                android:textColor="@color/white"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="@id/top_margin_2_2"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/left_margin"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintHorizontal_bias="0"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_app_update"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_10_white"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="@id/txt_app_version_margin_end"
                app:layout_constraintBottom_toBottomOf="@id/txt_app_version_margin_end"
                app:layout_constraintStart_toEndOf="@id/txt_app_version_margin_end"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.1929260450160772"
                app:layout_constraintHeight_percent="0.08"
                app:layout_constraintHorizontal_bias="0">

                <TextView
                    android:id="@+id/txt_app_update"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:gravity="center"
                    android:text="업데이트"
                    android:textColor="@color/black"
                    android:autoSizeTextType="uniform"
                    android:autoSizeStepGranularity="1dp"
                    android:maxLines="1"
                    android:fontFamily="@font/pretendard_bold"
                    app:layout_constraintWidth_percent="0.5083333333333333"
                    app:layout_constraintHeight_percent="0.625"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/top_margin_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.416"
                android:orientation="horizontal"
                />

            <TextView
                android:id="@+id/txt_emd_db"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:text="법정동 주소 DB"
                android:textSize="50dp"
                android:textColor="@color/white"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_bold"
                app:layout_constraintHeight_percent="0.068"
                app:layout_constraintTop_toTopOf="@id/top_margin_3"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/left_margin"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintHorizontal_bias="0"
                />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/top_margin_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.514"
                android:orientation="horizontal"
                />

            <TextView
                android:id="@+id/txt_emd_db_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="버전: 20251113052323"
                android:textSize="26dp"
                android:textColor="@color/white"
                app:layout_constraintTop_toTopOf="@id/top_margin_4"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/left_margin"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintHorizontal_bias="0"
                />

            <View
                android:id="@+id/txt_emd_db_version_margin_end"
                android:layout_width="0dp"
                android:layout_height="1dp"
                app:layout_constraintTop_toTopOf="@id/txt_emd_db_version"
                app:layout_constraintBottom_toBottomOf="@id/txt_emd_db_version"
                app:layout_constraintStart_toEndOf="@id/txt_emd_db_version"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.0401929260450161"
                app:layout_constraintHorizontal_bias="0"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_emd_db_update"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/background_edge_10_white"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="@id/txt_emd_db_version_margin_end"
                app:layout_constraintBottom_toBottomOf="@id/txt_emd_db_version_margin_end"
                app:layout_constraintStart_toEndOf="@id/txt_emd_db_version_margin_end"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.1929260450160772"
                app:layout_constraintHeight_percent="0.08"
                app:layout_constraintHorizontal_bias="0">

                <TextView
                    android:id="@+id/txt_emd_db_update"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:gravity="center"
                    android:text="업데이트"
                    android:textColor="@color/black"
                    android:autoSizeTextType="uniform"
                    android:autoSizeStepGranularity="1dp"
                    android:maxLines="1"
                    android:fontFamily="@font/pretendard_bold"
                    app:layout_constraintWidth_percent="0.5083333333333333"
                    app:layout_constraintHeight_percent="0.625"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/top_margin_4_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.594"
                android:orientation="horizontal"
                />

            <TextView
                android:id="@+id/txt_emd_db_version_recent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="최신 소프트웨어 입니다."
                android:textSize="26dp"
                android:textColor="@color/white"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="@id/top_margin_4_2"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/left_margin"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintHorizontal_bias="0"
                />

            <TextView
                android:id="@+id/txt_progress"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:text="업데이트 파일 다운로드중..."
                android:textColor="@color/gray_abacb3"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:fontFamily="@font/pretendard_medium"
                android:visibility="gone"
                app:layout_constraintHeight_percent="0.0366666667"
                app:layout_constraintBottom_toTopOf="@id/top_margin_lo_progress"
                app:layout_constraintStart_toStartOf="@id/lo_progress"
                app:layout_constraintEnd_toEndOf="@id/lo_progress"
                />

            <View
                android:id="@+id/top_margin_lo_progress"
                android:layout_width="1dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toTopOf="@id/lo_progress"
                app:layout_constraintStart_toStartOf="@id/lo_progress"
                app:layout_constraintEnd_toEndOf="@id/lo_progress"
                app:layout_constraintHeight_percent="0.02"
                />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lo_progress"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintHeight_percent="0.012"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/left_margin"
                app:layout_constraintEnd_toEndOf="@id/right_margin"
                app:layout_constraintVertical_bias="0.9">

            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_loading"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_circular"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="5dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:indicatorColor="@color/background"
                app:layout_constraintWidth_percent="0.2"
                app:layout_constraintDimensionRatio="1:1"
                android:indeterminate="true"
                />


        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>