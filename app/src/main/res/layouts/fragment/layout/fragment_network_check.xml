<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lo_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_top"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.1516666666666667"
            app:layout_constraintVertical_bias="0">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@drawable/icon_main_logo"
                app:layout_constraintHorizontal_bias="0.0416666666666667"
                app:layout_constraintWidth_percent="0.125"
                app:layout_constraintHeight_percent="0.5164835164835165"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

            <TextView
                android:id="@+id/text1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="@string/str_main_title"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/white"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="start"
                app:layout_constraintWidth_percent="0.4229166666666667"
                app:layout_constraintHeight_percent="0.4285714285714286"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.97"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/white_10"
            app:layout_constraintHeight_percent="0.1133333333333333"
            app:layout_constraintTop_toBottomOf="@id/lo_top"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0">

            <TextView
                android:id="@+id/text2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="@string/str_step_0_text_1"
                android:fontFamily="@font/pretendard_medium"
                android:textColor="@color/gray_abacb3"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="center"
                app:layout_constraintHeight_percent="0.4117647058823529"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/text3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str_network_check"
            android:fontFamily="@font/pretendard_medium"
            android:textColor="@color/white"
            android:textSize="30dp"
            android:lineSpacingMultiplier="1.5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btn_skip"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.2104166666666667"
            app:layout_constraintHeight_percent="0.0966666666666667"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.92"
            android:background="@drawable/background_edge_30_transparent_outline_green"
            android:clipToOutline="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="@string/str_skip"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/communicate_green"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="top"
                app:layout_constraintHorizontal_bias="0.45"
                app:layout_constraintWidth_percent="0.3693693693693694"
                app:layout_constraintHeight_percent="0.5862068965517241"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

            <kr.co.kworks.goodmorning.view.Circle
                android:id="@+id/circle"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:color="@color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintHeight_percent="0.7241379310344828"
                app:layout_constraintHorizontal_bias="0.96"
                />

            <TextView
                android:id="@+id/txt_count"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:fontFamily="@font/pretendard_medium"
                android:textColor="@color/black"
                android:textSize="80dp"
                android:autoSizeTextType="uniform"
                android:autoSizeStepGranularity="1dp"
                android:maxLines="1"
                android:gravity="center"
                android:text="8"
                app:layout_constraintTop_toTopOf="@id/circle"
                app:layout_constraintBottom_toBottomOf="@id/circle"
                app:layout_constraintStart_toStartOf="@id/circle"
                app:layout_constraintEnd_toEndOf="@id/circle"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>