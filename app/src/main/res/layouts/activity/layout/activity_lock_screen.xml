<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/lo_main"
        android:background="@drawable/background_gradient_blue_green">

        <ImageView
            android:id="@+id/text1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/goodmorning"

            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.2051282051"
            app:layout_constraintHeight_percent="0.0308056872"
            app:layout_constraintVertical_bias="0.05"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_datetime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.28">

            <TextView
                android:id="@+id/txt_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11:08"
                android:textSize="100dp"
                android:textColor="@color/white"
                android:fontFamily="@font/pretendard_medium"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                />

            <TextView
                android:id="@+id/txt_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026년 3월 13일 금요일"
                android:textSize="22dp"
                android:textColor="@color/white"
                android:fontFamily="@font/pretendard_medium"
                app:layout_constraintTop_toBottomOf="@id/txt_time"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_wise"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/lo_datetime"
            app:layout_constraintBottom_toTopOf="@id/lo_seekbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="1"
            app:layout_constraintWidth_percent="0.87"
            android:background="@drawable/background_edge_20_transparent_black_20"
            android:layout_marginBottom="20dp"
            android:padding="20dp">

            <TextView
                android:id="@+id/txt_wise"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:maxHeight="140dp"
                app:layout_constraintHeight_max="120dp"
                android:ellipsize="end"
                android:textColor="@color/white"
                android:text="@string/sentence_sample_long"
                android:textSize="22dp"
                android:fontFamily="@font/pretendard_medium"
                android:lineSpacingMultiplier="1.2"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                />

            <TextView
                android:id="@+id/txt_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:maxHeight="40dp"
                app:layout_constraintHeight_max="120dp"
                android:ellipsize="end"
                android:textColor="@color/white"
                android:text="@string/str"
                android:fontFamily="@font/pretendard_medium"
                android:lineSpacingMultiplier="1.2"
                android:textSize="22dp"
                android:gravity="end"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/txt_wise"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lo_seekbar"
            android:layout_width="0dp"
            android:layout_height="70dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.93"
            app:layout_constraintWidth_percent="0.87"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>