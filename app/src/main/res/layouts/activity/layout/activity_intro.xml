<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/lo_main"
        android:background="@color/black_000219">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/icon_svg"
            app:layout_constraintWidth_percent="0.21"
            app:layout_constraintHeight_percent="0.31"
            app:layout_constraintVertical_bias="0.367"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txt_title"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="대형산불 대응 지능형 솔루션 개발"
            android:textSize="50dp"
            android:autoSizeTextType="uniform"
            android:autoSizeStepGranularity="1dp"
            android:textColor="@color/white"
            android:maxLines="1"
            android:gravity="center"
            android:fontFamily="@font/pretendard_bold"
            app:layout_constraintWidth_percent="0.4229166666666667"
            app:layout_constraintHeight_percent="0.065"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.7"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>