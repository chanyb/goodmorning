<?xml version="1.0" encoding="utf-8"?>
<layout>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/lo_dialog"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black_70"
        android:visibility="gone">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/background_edge_white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.9">

            <TextView
                android:id="@+id/txt_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="24dp"
                android:fontFamily="@font/pretendard_semibold"
                android:text="팝업제목"
                android:textColor="@color/black"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0.1"
                app:layout_constraintWidth_percent="0.85"
                />

            <TextView
                android:id="@+id/txt_body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="팝업텍스트영역입니다.\n최소높이를지켜주세요."
                android:textSize="18dp"
                android:textColor="@color/black"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginTop="10dp"
                android:minHeight="50dp"
                app:layout_constraintTop_toBottomOf="@id/txt_title"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/txt_title"
                app:layout_constraintEnd_toEndOf="@id/txt_title"
                app:layout_constraintVertical_bias="0"
                />

            <View
                android:id="@+id/guide_btn"
                android:layout_width="18dp"
                android:layout_height="48dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txt_body"
                app:layout_constraintBottom_toBottomOf="parent"
                />

            <TextView
                android:id="@+id/btn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:text="확인"
                android:gravity="center"
                android:textSize="18dp"
                android:textColor="@color/white"
                android:background="@drawable/background_edge_10_blue"
                android:fontFamily="@font/pretendard_semibold"
                app:layout_constraintTop_toTopOf="@id/guide_btn"
                app:layout_constraintBottom_toBottomOf="@id/guide_btn"
                app:layout_constraintStart_toStartOf="@id/txt_title"
                app:layout_constraintEnd_toEndOf="@id/txt_title"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>